                    <h6 class="text-gold text-uppercase small fw-bold mb-4 tracking-widest" data-translate="quick_links">Quick Links</h6>
                    <ul class="list-unstyled d-flex flex-wrap gap-3">
                        <li><a href="#" class="footer-link" data-translate="home">Home</a></li>
                        <li><a href="#" class="footer-link" data-translate="about">About</a></li>
                        <li><a href="#projects-section" class="footer-link" data-translate="our_projects_footer">Our Projects</a></li>
