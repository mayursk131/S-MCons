                    </ul>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex gap-3 justify-content-lg-end mb-4">
                        <a href="#" class="text-gold fs-5"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="text-gold fs-5"><i class="fa-brands fa-linkedin"></i></a>
                        <a href="#" class="text-gold fs-5"><i class="fa-brands fa-facebook"></i></a>
                    </div>
                    <p class="text-muted small" data-translate="copyright"> 2026 S&M Infrastructures. Built for Excellence.</p>
                </div>
            </div>
        </div>
    

    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.min.js"></script>
    <script src="../scripts/utils/language.js"></script>
    <script src="../scripts/components/main.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize language selector for main page
            if (typeof languageManager !== 'undefined') {
                const selectorContainer = document.getElementById('mainLanguageSelector');
                if (selectorContainer) {
                    selectorContainer.innerHTML = languageManager.createLanguageSelector();
                }
                
                // Force logo update on page load
                setTimeout(() => {
                    if (languageManager && languageManager.updateLogo) {
                        languageManager.updateLogo();
                    }
                }, 100);
            }
        });
    </script>

</body>

</html>