<body>

    <section class="hero-section">
        <div class="video-container">
            <video id="heroVideo" autoplay muted loop playsinline>
                <source src="../assets/videos/4k.mp4" type="video/mp4">
            </video>
        </div>

        <nav class="navbar py-3" id="mainNav">
            <div class="container-fluid px-4 px-md-5 d-flex justify-content-between align-items-center">
                <div class="logo-box">
                    <h2 class="fw-bold mb-0" id="smlogo">S<span class="text-gold">&</span>M <span
                            class="text-gold">INFRA</span></h2>
                </div>
                <div class="d-none d-lg-flex gap-5">
                    <a href="projects.html"
                        class="nav-link-custom text-decoration-none small tracking-widest fw-bold" data-translate="our_projects">OUR PROJECTS</a>
                    <a href="legacy.html" class="nav-link-custom text-decoration-none small tracking-widest fw-bold" data-translate="our_legacy">OUR
                        LEGACY</a>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <div id="mainLanguageSelector"></div>
                    <a href="#contact-us" class="btn btn-outline-light d-none d-sm-block px-4 py-2 small"
                        style="border-radius: 0;" data-translate="enquire_now">Enquire Now</a>
                    <div class="menu-toggle" id="menuBtn">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>
        </nav>

        <div id="fullMenu">
            <div class="menu-items text-center">
                <a href="#" data-translate="home">Home</a>
                <a href="#projects-section" data-translate="our_projects">Our Projects</a>
                <a href="#" data-translate="our_story">Our Story</a>
                <a href="#contact-us" id="menuContact" data-translate="contact">Contact</a>
            </div>
        </div>

        <main class="hero-wrap container-fluid px-5">
            <div class="hero-text px-md-5">
                <h4 class="text-gold text-uppercase fw-bold mb-4 tracking-extra" data-translate="future_of_living">The Future of Living</h4>
                <h1 class="display-1 fw-bold mb-4" data-translate="redefining_luxury">Redefining<br>Luxury Landscapes.</h1>
                <p class="opacity-75 lead fw-light mb-5 max-w-500" data-translate="we_dont_just_build">
                    We don't just build structures; we create a new lifestyle that blends modern design with lasting durability.
                </p>
                <button onclick="document.getElementById('projects-section').scrollIntoView({behavior: 'smooth'})"
                    class="btn btn-light rounded-0 px-5 py-3 text-uppercase fw-bold tracking-widest"
                    style="font-size: 12px;" data-translate="view_portfolio">View Portfolio</button>
            </div>
        </main>
    </section>

    <section class="stats-section py-5 bg-black  border-gold border-opacity-10">
        <div class="container py-4">
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <h2 class="display-4 fw-bold text-gold counter-value" data-target="14">0</h2>
                    <p class="small text-uppercase tracking-widest opacity-60" data-translate="years_of_legacy">Years of Legacy</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h2 class="display-4 fw-bold text-gold"><span class="counter-value" data-target="15">0</span>+</h2>
                    <p class="small text-uppercase tracking-widest opacity-60" data-translate="landmarks">Landmarks</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h2 class="display-4 fw-bold text-gold"><span class="counter-value" data-target="5">0</span>M+</h2>
                    <p class="small text-uppercase tracking-widest opacity-60" data-translate="sqft_developed">Sq.Ft. Developed</p>
                </div>
            </div>
        </div>
    </section>

    <section class="about-premium">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 reveal">
                    <div class="pe-lg-5">
                        <h6 class="text-gold text-uppercase tracking-extra fw-bold mb-3" data-translate="nagpurs_pride">Nagpur's Pride</h6>
                        <h2 class="display-4 fw-bold mb-4" data-translate="legacy_built_on_excellence">A Legacy Built on <span class="text-gold">Excellence</span>.</h2>
                        <p class="lead text-white-50 mb-5" data-translate="sm_infra_description">
                            S&M Infra is new name for luxury living in Nagpur. We don't just build concrete structures; we create a strong foundation for dreams.
                        </p>
                        <div class="mission-vision mb-5">
                            <div class="mb-4">
                                <h5
                                    class="text-gold d-flex align-items-center gap-3 text-uppercase small fw-bold tracking-widest" data-translate="mission">
                                    <span class="gold-line"></span> Mission
                                </h5>
                                <p class="text-white-50 ps-4 small" data-translate="mission_description">To provide people with their dream homes through modern design and top-tier quality.</p>
                            </div>
                            <div>
                                <h5
                                    class="text-gold d-flex align-items-center gap-3 text-uppercase small fw-bold tracking-widest" data-translate="vision">
                                    <span class="gold-line"></span> Vision
                                </h5>
                                <p class="text-white-50 ps-4 small" data-translate="vision_description">To become the biggest name for innovation and trust in India's infrastructure industry.</p>
                            </div>
                        </div>
                        <a href="#" class="btn btn-outline-gold px-5 py-3 text-uppercase tracking-widest"
                            style="border-radius:0;" data-translate="discover_more">Discover More</a>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0 reveal">
                    <div class="main-img-wrapper">
                        <div class="image-border-accent"></div>
                        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop"
                            alt="Build" class="img-fluid main-about-img">
                        <div class="experience-badge">
                            <span class="exp-num">14+</span>
                            <span class="exp-text">Years Of <br> Excellence</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="projects-section" class="projects-section">
        <div class="container">
            <div class="text-center mb-5 reveal">
                <h2 class="display-5 fw-bold mb-4" data-translate="our_portfolio">Our Portfolio</h2>
                <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
                    <button class="filter-btn active" data-filter="all" data-translate="all">All</button>
                    <button class="filter-btn" data-filter="commercial" data-translate="commercial">Commercial</button>
                    <button class="filter-btn" data-filter="residential" data-translate="residential">Residential</button>
                </div>
            </div>

            <div class="project-slider">
                <div class="project-slide-item commercial">
                    <div class="project-card border-0">
                        <div class="position-relative overflow-hidden">
                            <div class="status-badge position-absolute top-0 start-0 m-3 py-1 px-3" data-translate="under_construction">Under Construction
                            </div>
                            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2070"
                                class="img-fluid w-100">
                        </div>
                        <div class="project-info p-4">
                            <h4 class="fw-bold mb-2" data-translate="corporate_plaza">Corporate Plaza</h4>
                            <p class="text-gold small mb-3"><i class="fa-solid fa-location-dot me-2"></i>Nagpur</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-gold-fill w-100 py-2 small" data-translate="book">Book</button>
                                <button class="btn btn-outline-gold w-100 py-2 small" data-translate="view">View</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="project-slide-item residential">
                    <div class="project-card border-0">
                        <div class="position-relative overflow-hidden">
                            <div class="status-badge position-absolute top-0 start-0 m-3 py-1 px-3" data-translate="upcoming">Upcoming</div>
                            <img src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?q=80&w=2070"
                                class="img-fluid w-100">
                        </div>
                        <div class="project-info p-4">
                            <h4 class="fw-bold mb-2" data-translate="infinity_heights">Infinity Heights</h4>
                            <p class="text-gold small mb-3"><i class="fa-solid fa-location-dot me-2"></i>Nagpur</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-gold-fill w-100 py-2 small" data-translate="book">Book</button>
                                <button class="btn btn-outline-gold w-100 py-2 small" data-translate="view">View</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="project-slide-item residential">
                    <div class="project-card border-0">
                        <div class="position-relative overflow-hidden">
                            <div class="status-badge position-absolute top-0 start-0 m-3 py-1 px-3 bg-white text-dark" data-translate="sold_out">Sold Out</div>
                            <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=2070"
                                class="img-fluid w-100">
                        </div>
                        <div class="project-info p-4">
                            <h4 class="fw-bold mb-2" data-translate="paris_city">Paris City</h4>
                            <p class="text-gold small mb-3"><i class="fa-solid fa-location-dot me-2"></i>Nagpur</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-gold w-100 py-2 small" disabled data-translate="sold_out">Sold Out</button>
                                <button class="btn btn-outline-gold w-100 py-2 small" data-translate="view">View</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="awards-section">
        <div class="container">
            <div class="text-center mb-5 reveal">
                <h2 class="display-5 fw-bold mb-2" data-translate="recognition">Recognition</h2>
                <p class="text-muted" data-translate="awards_description">Awards for construction and innovation.</p>
            </div>
            <div class="row g-4 justify-content-center">
                <div class="col-lg-4 col-md-6 reveal">
                    <div class="award-card text-start">
                        <span class="award-category mb-4 d-inline-block" data-translate="excellence">Excellence</span>
                        <h4 class="mb-3" data-translate="ici_award">ICI Award</h4>
                        <p class="text-muted small" data-translate="outstanding_concrete">Outstanding Concrete Structure recognition for Infinity.</p>
                        <hr class="opacity-10">
                        <span class="text-gold small fw-bold" data-translate="winner_2024">2024 Winner</span>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 reveal" style="transition-delay: 0.2s;">
                    <div class="award-card text-start">
                        <span class="award-category mb-4 d-inline-block" data-translate="leadership">Leadership</span>
                        <h4 class="mb-3" data-translate="et_icons">ET Icons</h4>
                        <p class="text-muted small" data-translate="industry_leadership">Recognized for industry leadership and vision.</p>
                        <hr class="opacity-10">
                        <span class="text-gold small fw-bold" data-translate="recipient_2023">2023 Recipient</span>
                    </div>
                </div>
            </div>
        </div>
