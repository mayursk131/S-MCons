    <section class="contact-section" id="contact-us">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-5 reveal">
                    <h2 class="display-5 fw-bold mb-4" data-translate="enquire_now_section">Enquire Now</h2>
                    <p class="text-muted mb-5" data-translate="lets_build_dream">Let's build your dream together.</p>
                    <div class="mb-4">
                        <h6 class="text-gold text-uppercase small fw-bold mb-2" data-translate="address">Address</h6>
                        <p class="opacity-75" data-translate="address_details">Civil Lines, Nagpur, 440001</p>
                    </div>
                    <div class="mb-4">
                        <h6 class="text-gold text-uppercase small fw-bold mb-2" data-translate="contact_details">Contact</h6>
                        <p class="opacity-75 mb-0" data-translate="phone_number">+91 7888012200</p>
                        <p class="opacity-75" data-translate="email_address">info@sm-infra.in</p>
                    </div>
                </div>
                <div class="col-lg-7 reveal">
                    <div class="p-4 p-md-5" style="background: #111; border: 1px solid var(--border-color);">
                        <form action="../backend/api/submit.php" method="POST">
                            <div class="mb-4">
                                <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="name">Name</label>
                                <input type="text" name="full_name" class="form-control custom-input"
                                    data-translate-placeholder="your_full_name" placeholder="Your Full Name" required>
                            </div>
                            <div class="mb-4">
                                <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="phone_no">Phone.No</label>
                                <input type="tel" name="phone_no" class="form-control custom-input"
                                    data-translate-placeholder="phone_no" placeholder="Phone.No." required>
                            </div>
                            <div class="mb-4">
                                <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="email">Email</label>
                                <input type="email" name="email_address" class="form-control custom-input"
                                    data-translate-placeholder="your_email_address" placeholder="Your Email Address" required>
                            </div>
                            <div class="mb-4">
                                <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="message">Message</label>
                                <textarea name="message" class="form-control custom-input" rows="4"
                                    data-translate-placeholder="tell_us_requirement" placeholder="Tell us about your requirement" required></textarea>
                            </div>
                            <button type="submit" name="submit_inquiry" class="btn btn-gold-fill w-100 py-3" data-translate="submit_inquiry">Submit
                                Inquiry</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
         <section class="feedback-section py-5"
            style="background: var(--darker-bg); border-top: 1px solid var(--border-color);">
            <div class="container py-4">
                <div class="row justify-content-center">
                    <div class="col-lg-8 text-center reveal">
                        <h6 class="text-gold text-uppercase tracking-extra fw-bold mb-3" data-translate="your_thoughts_matter">Your Thoughts Matter</h6>
                        <h2 class="display-5 fw-bold mb-5" data-translate="give_us_feedback">Give Us <span class="text-gold">Feedback</span></h2>

                        <div class="feedback-container p-4 p-md-5">
                            <form action="../backend/api/feedback.php" method="POST">
                                <div class="row g-4">
                                    <div class="col-12 mb-3">
                                        <label class="small text-gold text-uppercase fw-bold d-block mb-3" data-translate="how_was_experience">How was your experience?</label>
                                        <div class="rating-wrapper">
                                            <input type="radio" name="rating" value="5" id="star5"><label
                                                for="star5">★</label>
                                            <input type="radio" name="rating" value="4" id="star4"><label
                                                for="star4">★</label>
                                            <input type="radio" name="rating" value="3" id="star3"><label
                                                for="star3">★</label>
                                            <input type="radio" name="rating" value="2" id="star2"><label
                                                for="star2">★</label>
                                            <input type="radio" name="rating" value="1" id="star1"><label
                                                for="star1">★</label>
                                        </div>
                                    </div>

                                    <div class="col-md-6 text-start">
                                        <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="subject">Subject</label>
                                        <select class="form-select custom-input" name="subject">
                                            <option value="service" data-translate="service_quality">Service Quality</option>
                                            <option value="design" data-translate="design_architecture">Design & Architecture</option>
                                            <option value="support" data-translate="customer_support">Customer Support</option>
                                            <option value="other" data-translate="other">Other</option>
                                        </select>
                                    </div>

                                    <div class="col-md-6 text-start">
                                        <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="name_optional">Name
                                            (Optional)</label>
                                        <input type="text" class="form-control custom-input" data-translate-placeholder="name" placeholder="Mayur">
                                    </div>

                                    <div class="col-12 text-start">
                                        <label class="small text-gold text-uppercase fw-bold mb-2" data-translate="suggestions">Suggestions</label>
                                        <textarea class="form-control custom-input" rows="3"
                                            data-translate-placeholder="how_can_improve" placeholder="How can we improve?"></textarea>
                                    </div>

                                    <div class="col-12">
                                        <button type="submit"
                                            class="btn btn-outline-gold px-5 py-3 mt-3 w-100 w-md-auto" data-translate="submit_feedback">Submit
                                            Feedback</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>


    <footer class="py-5 bg-black border-top border-gold border-opacity-10">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h2 class="fw-bold mb-4" id="footerLogo">S<span class="text-gold">&</span>M <span class="text-gold">INFRA</span>
                    </h2>
                    <p class="text-muted small" data-translate="nagpurs_leading">Nagpur's leading real estate developer crafting premium landscapes.</p>
                </div>
